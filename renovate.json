{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "argocd": {
    "managerFilePatterns": [
      "/argo/.+\\.ya?ml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)gatus\\.ya?ml$/"
      ],
      "matchStrings": [
        "tag:\\s*\"?(?<currentValue>[^\"\\s]+)\"?\\s*#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)"
      ],
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^argo\\/system\\/oracle-[^/]+\\/kustomization\\.ya?ml$/"
      ],
      "matchStrings": [
        "-\\s*https://raw\\.githubusercontent\\.com/oracle/oci-cloud-controller-manager/refs/tags/(?<currentValue>v\\d+\\.\\d+\\.\\d+)/[^\\s]+\\s*#\\s*renovate:\\s*datasource=github-tags\\s+depName=oracle/oci-cloud-controller-manager"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "oracle/oci-cloud-controller-manager",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^argo\\/system\\/system-upgrade-controller\\/plan\\.yaml$/"
      ],
      "matchStrings": [
        "version:\\s*\"(?<currentValue>[^\"]+)\"\\s*#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)"
      ],
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^argo\\/(apps\\/gatus\\/rollout-hooks|system\\/system-upgrade-controller\\/plan)\\.ya?ml$/"
      ],
      "matchStrings": [
        "image:\\s*\"?ghcr\\.io/anokfireball/base-image:(?<currentValue>[^@\"\\s]+)@(?<currentDigest>sha256:[a-f0-9]+)\"?\\s*#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "terraform/variables.tf"
      ],
      "matchStrings": [
        "default\\s*=\\s*\"(?<currentValue>[^\"]+)\"\\s*#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)"
      ],
      "versioningTemplate": "semver"
    }
  ],
  "kustomize": {
    "managerFilePatterns": [
      "/argo/.+kustomization\\.ya?ml$/"
    ]
  }
}
